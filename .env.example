# Skopiuj ten plik do `.env` i uzupełnij własnymi kluczami.
# Plik `.env` jest w .gitignore i NIE trafia do repozytorium.

# --- Opcja A: Google AI Studio (klucz API) ---
# Klucz z https://aistudio.google.com/ — generacja obrazów kart (Gemini).
GEMINI_API_KEY=

# --- Opcja B: Vertex AI (Google Cloud, budżet 300$ z trialu) ---
# Zamiast klucza używa logowania ADC (gcloud auth application-default login).
# Ustaw true, podaj ID projektu GCP i region (wymaga włączonego Vertex AI API).
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Opcjonalny własny klucz do innego modelu AI (np. Claude / dowolny provider).
CUSTOM_API_KEY=
